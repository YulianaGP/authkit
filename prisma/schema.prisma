// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")          // pooler URL — used at runtime
  directUrl = env("DATABASE_URL_UNPOOLED") // direct URL — used by prisma db push / migrate
}


// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGIN_2FA
  LOGOUT
  LOGOUT_ALL
  REGISTER
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET
  EMAIL_VERIFIED
  PROFILE_UPDATED
  AVATAR_UPDATED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  SESSION_REVOKED
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  password          String?   // null for OAuth-only users
  role              Role      @default(USER)

  // 2FA
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?   // encrypted TOTP secret

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  auditLogs         AuditLog[]
  passwordResets    PasswordReset[]
  recoveryCodes     RecoveryCode[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// NextAuth — OAuth accounts
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ---------------------------------------------------------------------------
// NextAuth — Database sessions
// ---------------------------------------------------------------------------

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ---------------------------------------------------------------------------
// NextAuth — Email verification tokens
// ---------------------------------------------------------------------------

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Password reset
// ---------------------------------------------------------------------------

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ---------------------------------------------------------------------------
// 2FA recovery codes
// ---------------------------------------------------------------------------

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    // bcrypt hash of the code
  usedAt    DateTime?

  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recovery_codes")
}

// ---------------------------------------------------------------------------
// Audit log — tracks all auth events with geo + device info
// ---------------------------------------------------------------------------

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  action    AuditAction
  ip        String?
  userAgent String?     @db.Text
  country   String?     // ISO 3166-1 alpha-2, e.g. "CO", "US"
  city      String?
  device    String?     // "desktop" | "mobile" | "tablet"
  browser   String?     // "Chrome 124" | "Safari 17" etc.
  os        String?     // "Windows 11" | "macOS 14" etc.
  success   Boolean     @default(true)
  metadata  Json?       // extra context per action

  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, action])
  @@map("audit_logs")
}
