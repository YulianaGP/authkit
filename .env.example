# ============================================================
# authkit — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL)
# Recommended: Neon (neon.tech) — free tier available
#
# Neon gives you two URLs — use both:
#   DATABASE_URL        → pooler URL (for runtime queries)
#   DATABASE_URL_UNPOOLED → direct URL (for prisma db push / migrations)
#
# The direct URL is the same as the pooler URL but without "-pooler"
# in the hostname. Example:
#   Pooler:  ep-plain-sea-a1b2c3d4-pooler.us-east-1.aws.neon.tech
#   Direct:  ep-plain-sea-a1b2c3d4.us-east-1.aws.neon.tech
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require"

# ------------------------------------------------------------
# NextAuth v5
# Generate AUTH_SECRET with: openssl rand -base64 32
# AUTH_URL is your app's base URL (no trailing slash)
# ------------------------------------------------------------
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# Google OAuth
# Create credentials at: https://console.cloud.google.com
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
# ------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ------------------------------------------------------------
# GitHub OAuth
# Create OAuth App at: https://github.com/settings/developers
# Authorized callback URL: {AUTH_URL}/api/auth/callback/github
# ------------------------------------------------------------
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ------------------------------------------------------------
# Discord OAuth
# Create app at: https://discord.com/developers/applications
# Redirect URI: {AUTH_URL}/api/auth/callback/discord
# ------------------------------------------------------------
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ------------------------------------------------------------
# Resend (email)
# Get your key at: https://resend.com
# Also configure your sending domain in the Resend dashboard
# ------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AuthKit <noreply@yourdomain.com>"

# ------------------------------------------------------------
# Upstash Redis (rate limiting)
# Create a database at: https://console.upstash.com
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------
# Seed — initial admin user (used by: npx prisma db seed)
# ------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="ChangeMe123"
SEED_ADMIN_NAME="Admin"
